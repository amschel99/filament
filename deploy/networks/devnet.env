# ── Filament LSP · DEVNET ─────────────────────────────────────────────────────
# Local CKB devnet + 3 fnn nodes (see infra/scripts/devnet-windows.sh). This is the ONLY network
# proven end-to-end on this machine. fnn auto-loads FundingLock/CommitmentLock from the dev genesis.
NETWORK=devnet

# Node RPC endpoints (hub is the LSP node).
HUB_RPC_URL=http://127.0.0.1:8227
CUSTOMER1_RPC_URL=http://127.0.0.1:8237
CUSTOMER2_RPC_URL=http://127.0.0.1:8247
CKB_RPC_URL=http://127.0.0.1:8114

# API
API_PORT=3000
API_KEY=devnet-static-key-change-me
DATABASE_PATH=./data/lsp.devnet.sqlite
LOG_LEVEL=info

# ── Stablecoin: fUSD (SIMPLE_UDT minted on the devnet by udt-init) ─────────────
STABLECOIN_NAME=fUSD
STABLECOIN_SYMBOL=$
STABLECOIN_DECIMALS=8
STABLECOIN_CODE_HASH=0xe1e354d6d643ad42724d40967e334984534e0367405c5ae42a9d7d63d77df419
STABLECOIN_HASH_TYPE=data2
STABLECOIN_ARGS=0x32e555f3ff8e135cece1351a6a2971518392c1e30375c1e006ad0ce8eac07947
# cell dep = genesis tx#0, simple_udt at output index 8
STABLECOIN_CELLDEP_TX_HASH=0xcfcbbe3426fc724b308b2cdb1177c26dd242e6f871b099eec86478ef8825ebd8
STABLECOIN_CELLDEP_INDEX=0x8
STABLECOIN_CELLDEP_DEP_TYPE=code
