# ── Filament LSP · TESTNET (Pudge) ────────────────────────────────────────────
# NOT run on this machine — template only. fnn recognizes the testnet genesis hash and auto-loads
# the correct FundingLock/CommitmentLock cell deps, so NO script hashes are configured here.
#
# Before launching:
#  1. Run an fnn node with fiber.chain: testnet (or the official testnet spec) + a synced/public
#     CKB testnet RPC. See deploy/README.md.
#  2. Fund the hub node's CKB wallet from a testnet faucet.
#  3. Fill the RUSD testnet type script below (VERIFY from the RUSD deployment — do NOT guess;
#     CLAUDE.md rule 2). Testnet RUSD may differ from mainnet.
NETWORK=testnet

HUB_RPC_URL=http://127.0.0.1:8227
CKB_RPC_URL=https://testnet.ckb.dev/rpc          # public CKB testnet RPC (or run your own)

API_PORT=3000
API_KEY=CHANGE_ME_TESTNET_KEY
DATABASE_PATH=./data/lsp.testnet.sqlite
LOG_LEVEL=info

# ── Stablecoin: RUSD (testnet) — FILL IN + VERIFY ─────────────────────────────
STABLECOIN_NAME=RUSD
STABLECOIN_SYMBOL=$
STABLECOIN_DECIMALS=8
STABLECOIN_CODE_HASH=0x__FILL_RUSD_TESTNET_CODE_HASH__
STABLECOIN_HASH_TYPE=type
STABLECOIN_ARGS=0x__FILL_RUSD_TESTNET_ARGS__
STABLECOIN_CELLDEP_TX_HASH=0x__FILL_RUSD_TESTNET_CELLDEP_TX__
STABLECOIN_CELLDEP_INDEX=0x0
STABLECOIN_CELLDEP_DEP_TYPE=code
