# ── Filament LSP · MAINNET ────────────────────────────────────────────────────
# NOT run on this machine — template only. REAL FUNDS. fnn recognizes the mainnet genesis hash and
# auto-loads the correct FundingLock/CommitmentLock cell deps; no script hashes configured here.
#
# ⚠ Before launching to mainnet, complete SECURITY.md hardening: rotate the API key, move node keys
#   off env-var passwords, enable Biscuit auth if the RPC leaves loopback, set rate limits. This
#   template is NOT production-hardened.
#
# Fill the RUSD mainnet type script below from the official Stables Labs / RUSD deployment. VERIFY
# every value on-chain (code_hash, hash_type, args, cell dep out_point) — never guess (CLAUDE.md
# rule 2). A wrong type script means invoices no one can pay, or worse.
NETWORK=mainnet

HUB_RPC_URL=http://127.0.0.1:8227
CKB_RPC_URL=https://mainnet.ckb.dev/rpc          # public CKB mainnet RPC (or run your own node)

API_PORT=3000
API_KEY=CHANGE_ME_STRONG_MAINNET_KEY
DATABASE_PATH=./data/lsp.mainnet.sqlite
LOG_LEVEL=info

# ── Stablecoin: RUSD (mainnet) — FILL IN + VERIFY ─────────────────────────────
STABLECOIN_NAME=RUSD
STABLECOIN_SYMBOL=$
STABLECOIN_DECIMALS=8
STABLECOIN_CODE_HASH=0x__FILL_RUSD_MAINNET_CODE_HASH__
STABLECOIN_HASH_TYPE=type
STABLECOIN_ARGS=0x__FILL_RUSD_MAINNET_ARGS__
STABLECOIN_CELLDEP_TX_HASH=0x__FILL_RUSD_MAINNET_CELLDEP_TX__
STABLECOIN_CELLDEP_INDEX=0x0
STABLECOIN_CELLDEP_DEP_TYPE=code
