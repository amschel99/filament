# ─────────────────────────────────────────────────────────────
# Dependencies & build output
# ─────────────────────────────────────────────────────────────
node_modules/
dist/
build/
*.tsbuildinfo
.npm/
.cache/

# ─────────────────────────────────────────────────────────────
# Env & secrets  (commit .env.example, never .env)
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ─────────────────────────────────────────────────────────────
# Fiber / CKB runtime state — NEVER commit.
# Leaking or losing a node key or the channel store can mean losing funds.
# ─────────────────────────────────────────────────────────────
infra/nodes/**/ckb/key
infra/nodes/**/fiber/
infra/nodes/**/store/
# rendered per-machine from scripts.json
infra/nodes/**/config.yml
infra/nodes/**/*.log
infra/nodes/**/*.pid
# devnet chain data (regenerated by reset.sh)
infra/devnet/data/
infra/devnet/*.tmp

# downloaded binaries (ckb/ckb-cli/fnn) and the cloned fiber harness — large, reproducible
infra/bin/
infra/vendor/
# NOTE: infra/devnet/scripts.json IS tracked — it is the source of truth for script hashes.

# ─────────────────────────────────────────────────────────────
# LSP database & local data
# ─────────────────────────────────────────────────────────────
data/
*.sqlite
*.sqlite-*
*.db
*.db-journal

# ─────────────────────────────────────────────────────────────
# Logs & coverage
# ─────────────────────────────────────────────────────────────
*.log
logs/
coverage/
.nyc_output/

# ─────────────────────────────────────────────────────────────
# AI assistant local state (keep CLAUDE.md — it's an intentional project doc)
# ─────────────────────────────────────────────────────────────
# Claude Code local settings/state (settings.local.json, etc.)
.claude/
.cursor/
.cursorrules
.cursorignore
.aider*
.continue/
.windsurf/
.codeium/
.github/copilot-instructions.md
.tabnine/
.serena/
llm-context/
*.aiderignore

# ─────────────────────────────────────────────────────────────
# Editors & IDEs
# ─────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.history/

# ─────────────────────────────────────────────────────────────
# OS cruft
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
