# deps & build
node_modules/
dist/
*.tsbuildinfo

# env & secrets
.env
.env.local
*.key

# runtime state — NEVER commit node keys or channel store (losing/leaking = losing funds)
infra/nodes/**/ckb/key
infra/nodes/**/fiber/
infra/nodes/**/*.log
infra/nodes/**/store/

# devnet chain data (regenerated by reset.sh)
infra/devnet/data/
infra/devnet/ckb.toml.bak

# generated at deploy time (kept out of VCS; scripts.json IS committed as the source of truth)
infra/devnet/*.tmp

# LSP database
*.sqlite
*.sqlite-*
*.db
data/

# logs & misc
*.log
.DS_Store
