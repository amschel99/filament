# ── LSP API service ─────────────────────────────────────────────
API_PORT=3000
API_KEY=devnet-static-key-change-me          # single static key on devnet (M5+)
DATABASE_PATH=./data/lsp.sqlite
LOG_LEVEL=info

# ── Fiber nodes (JSON-RPC endpoints) ────────────────────────────
# Hub is the LSP node; customer1 simulates a merchant, customer2 a buyer.
HUB_RPC_URL=http://127.0.0.1:8227
CUSTOMER1_RPC_URL=http://127.0.0.1:8237
CUSTOMER2_RPC_URL=http://127.0.0.1:8247

# ── Liquidity policy (Phase 3) ──────────────────────────────────
LSP_MIN_PROVISION_CKB=100
LSP_MAX_PROVISION_CKB=100000
LSP_CHANNEL_RESERVE_CKB=99                    # 98 commitment-lock + 1 shutdown fee, per side
LSP_FEE_PROPORTIONAL_MILLIONTHS=1000         # 0.1% default forwarding fee
LSP_REBALANCE_THRESHOLD_CKB=100

# ── Pollers (Phase 3/4), milliseconds ───────────────────────────
CHANNEL_MONITOR_INTERVAL_MS=5000
INVOICE_WATCH_INTERVAL_MS=3000

# ── Webhooks (Phase 4) ──────────────────────────────────────────
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_BACKOFF_BASE_MS=2000

# NOTE: FIBER_SECRET_KEY_PASSWORD is per-node and set by infra/scripts/start-nodes.sh,
# NOT read by the LSP service. It never belongs in the service .env.
